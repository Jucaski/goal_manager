<h1>My Balance Dashboard</h1>

<hr>
<div style="display: flex; gap: 20px; margin-bottom: 20px;">
  <div>
    <h3>Add Income</h3>
    <%= form_with model: @new_entry, url: create_entry_path, local: true do |f| %>
      <%= f.hidden_field :entry_type, value: 'income' %>
      <%= f.text_field :description, placeholder: "Income description" %>
      <%= f.number_field :amount, step: 0.01, placeholder: "$" %>
      <%= f.select :source_or_category, ['National', 'Foreign'], prompt: "Select origin" %>
      <%= f.date_field :date %>
      <%= f.submit "Add Income" %>
    <% end %>
  </div>

  <div>
    <h3>Add Outcome</h3>
    <%= form_with model: @new_entry, url: create_entry_path, local: true do |f| %>
      <%= f.hidden_field :entry_type, value: 'outcome' %>
      <%= f.text_field :description, placeholder: "Outcome description" %>
      <%= f.number_field :amount, step: 0.01, placeholder: "$" %>
      <%= f.select :source_or_category, ['Amazon_Food','Food','Necessary', 'Side_Project_Build', 'Side_Project_Tech', 'Study','Transportation',  'Other'], prompt: "Select category" %>
      <%= f.date_field :date %>
      <%= f.submit "Add Outcome" %>
    <% end %>
  </div>
</div>

<h3>Declaration Tax Month (<%= @previous_month_date.strftime("%B") %>)</h3>

<table border="1" style="border-collapse: collapse; width: 100%;">
  <tr style="background-color: #f3e8e8;">
    <th style="text-align: left; padding: 5px;">Description</th>
    <th style="text-align: left; padding: 5px;">Date</th>
    <th style="text-align: left; padding: 5px;">Balance</th>
  </tr>

  <% @previous_month_incomes.each do |income| %>
    <tr>
      <td style="padding: 5px;"><%= income.description %></td>
      <td style="padding: 5px;"><%= income.date.strftime("%d/%m/%Y") %></td>
      <td style="color: green;">+ <%= number_to_currency(income.amount) %></td>
    </tr>

    <% isr = income.amount * 0.01 %>
    <tr>
      <td style="padding: 5px;">ISR (1%)</td>
      <td></td>
      <td style="color: red; padding: 5px;">- $<%= '%.2f' % isr %></td>
    </tr>

    <% if income.source_or_category.to_s.downcase == 'foreign' %>
      <tr>
        <td style="padding: 5px;">IVA (0% for foreign)</td>
        <td></td>
        <td style="padding: 5px;">$0.00</td>
      </tr>
    <% else %>
      <% iva = income.amount * 0.16 %>
      <tr>
        <td style="padding: 5px;">IVA (16% for national)</td>
        <td></td>
        <td style="color: red; padding: 5px;">- $<%= '%.2f' % iva %></td>
      </tr>
    <% end %>
  <% end %>
  
  <% if @previous_month_incomes.empty? %>
    <tr>
      <td colspan="3" style="text-align: center; padding: 10px;">No incomes recorded for <%= @previous_month_date.strftime("%B") %>.</td>
    </tr>
  <% end %>
</table>
<hr>
<h3>Current Month Transactions</h3>
<table border="1">
  <tr>
    <th>Description</th>
    <th>Date</th>
    <th>Income</th>
    <th>Outcome</th>
  </tr>
  <% @entries.each do |entry| %>
    <tr>
      <td>
        <%= link_to entry.description, edit_balance_entry_path(entry), style: "text-decoration: underline; color: #000;" %>
      </td>
      <td><%= entry.date.strftime("%d/%m/%Y") %></td>
      <% if entry.entry_type == 'income' %>
        <td style="color: green;">+ $<%= entry.amount %></td>
        <td></td>
      <% else %>
        <td></td>
        <td style="color: red;">- $<%= entry.amount %></td>
      <% end %>
    </tr>
  <% end %>
  <tr>
    <td colspan="2"><strong>Total Balance</strong></td>
    <td colspan="1" style="text-align: center; color: green;"><strong><%= number_to_currency(@total_income) %></strong></td>
    <td colspan="1" style="text-align: center; color: red"><strong><%= number_to_currency(@total_outcome) %></strong></td>
  </tr>
</table>



<hr>
<h3>Year (<%= Time.current.year %>)</h3>

<table border="1" style="width: 100%; border-collapse: collapse; text-align: center;">
  <tr style="background-color: #dbeafe;">
    <th>Month</th>
    <th>Income</th>
    <th>Outcome</th>
  </tr>
  
  <% @monthly_data.each do |month_num, data| %>
    <%# Let's only display months up to the current month to keep the table clean %>
    <% if month_num <= Time.current.month %>
      <tr>
        <td><%= data[:name] %></td>
        <td style="background-color: #00ff00; color: black;">
          + <%= number_to_currency(data[:income]) %>
        </td>
        <td style="background-color: #ff0000; color: white;">
          - <%= number_to_currency(data[:outcome]) %>
        </td>
      </tr>
    <% end %>
  <% end %>

  <tr style="background-color: #dbeafe; font-weight: bold;">
    <td>Balance</td>
    <td style="background-color: #00ff00; color: black;">
      + <%= number_to_currency(@yearly_total_income) %>
    </td>
    <td style="background-color: #ff0000; color: white;">
      - <%= number_to_currency(@yearly_total_outcome) %>
    </td>
  </tr>
</table>

<br>

<div style="display: flex; flex-direction: column; gap: 10px; width: 300px; font-size: 1.2em;">
  
  <div style="display: flex; justify-content: space-between;">
    <span>Current Month Balance:</span>
    <span style="background-color: #d3d3d3; padding: 2px 20px; font-weight: bold;">
      <%= number_to_currency(@current_balance) %>
    </span>
  </div>

  <div style="display: flex; justify-content: space-between;">
    <span>Year Balance:</span>
    <span style="background-color: #00ff00; padding: 2px 20px; font-weight: bold; color: black;">
      <%= @yearly_balance >= 0 ? '+' : '-' %> <%= number_to_currency(@yearly_balance.abs) %>
    </span>
  </div>

</div>
