<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Goal Manager" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Goal Manager">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  </head>

  <body>
    <div class="container-fluid body-container">
    <div class="row flex-nowrap">

      <div class="col-auto col-md-3 col-xl-2 px-sm-2 px-0 py-5 side-bar vh-100 sticky-top d-flex flex-column">
        <nav class="navbar navbar-expand flex-column align-items-start px-0 border-sidebar w-100 flex-grow-1">
          <div class="collapse navbar-collapse flex-column align-items-start w-100 flex-grow-1"> 
            <ul class="navbar-nav nav-pills flex-column mb-auto w-100 h-100" id="menu">
              <li class="nav-item nav-design-data">
                <%= link_to habits_path, class: "nav-link px-2 py-3 d-flex align-items-center #{'active' if current_page?(habits_path)}" do %>
                  <i class="material-symbols-outlined">mountain_flag</i>
                  <span class="ms-1 d-none d-sm-inline">Did I do my best to</span>
                <% end %>
              </li>
              <li class="nav-item nav-design">
                <%= link_to day_habits_path, class: "nav-link px-2 py-3 d-flex align-items-center #{'active' if current_page?(day_habits_path)}" do %>
                  <i class="material-symbols-outlined">altitude</i>
                  <span class="ms-1 d-none d-sm-inline">Habits</span>
                <% end %>
              </li>
              <li class="nav-item nav-design">
                <%= link_to balance_path, class: "nav-link px-2 py-3 d-flex align-items-center #{'active' if current_page?(balance_path)}" do %>
                  <%# <i class="material-symbols-outlined">monitoring</i> %>
                  <span class="material-symbols-outlined">account_balance</span>
                  <span class="ms-1 d-none d-sm-inline">Balance</span>
                <% end %>
              </li>
              <li class="flex-grow-1"></li>
              <li class="nav-item nav-design">
                <hr class="w-100">
                <%= link_to settings_path, class: "nav-link px-2 py-3 d-flex align-items-center #{'active' if current_page?(settings_path)}" do %>
                  <i class="material-symbols-outlined">settings</i>
                  <span class="ms-1 d-none d-sm-inline">Settings</span>
                <% end %>
              </li>
            </ul>
          </div>
        </nav>
      </div>

      <% if user_signed_in? %>
        <div class="col py-3" style="min-width: 0;">
          <div class="container-fluid px-1 px-md-3">
            <%= yield %>
          </div>
        </div>
      <% else %>
        <div class="container mt-5">
          <%= yield %>
        </div>
      <% end %>

    </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        // 1. Get the saved theme, default to 'pink'
        const currentTheme = localStorage.getItem('app-theme') || 'pink';
        document.documentElement.setAttribute('data-theme', currentTheme);

        // 2. If the user is on the Settings page, make the dropdown match the current theme
        const themeSelector = document.getElementById('themeSelector');
        if (themeSelector) {
          themeSelector.value = currentTheme;
        }
      });

      // 3. Function triggered by your new buttons/dropdown
      function setTheme(themeName) {
        document.documentElement.setAttribute('data-theme', themeName);
        localStorage.setItem('app-theme', themeName);
      }
    </script>

  </body>
</html>
